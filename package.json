{
  "name": "@stellar-explorer/monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "dev": "bun run dev:web",
    "build": "bun run build:web",
    "lint": "bun run lint:web",
    "test": "bun run test:web",
    "format": "bun run format:web",
    "dev:web": "bun run --cwd apps/explorer-web dev",
    "build:web": "bun run --cwd apps/explorer-web build",
    "start:web": "bun run --cwd apps/explorer-web start",
    "lint:web": "bun run --cwd apps/explorer-web lint",
    "test:web": "bun run --cwd apps/explorer-web test",
    "format:web": "bun run --cwd apps/explorer-web format",
    "format:check:web": "bun run --cwd apps/explorer-web format:check",
    "tui:build": "make -C apps/tui build",
    "tui:install": "make -C apps/tui install",
    "tui:run": "make -C apps/tui run",
    "tui:run:rpc": "make -C apps/tui run-rpc",
    "tui:run:once": "make -C apps/tui run-once",
    "tui:run:hybrid": "make -C apps/tui run-hybrid",
    "tui:run:hybrid:once": "make -C apps/tui run-hybrid-once",
    "tui:test": "make -C apps/tui test-all",
    "tui:test:unit": "make -C apps/tui test",
    "tui:test:integration": "make -C apps/tui test-integration",
    "dev:docs": "bun run --cwd apps/docs dev",
    "build:docs": "bun run --cwd apps/docs build",
    "preview:docs": "bun run --cwd apps/docs preview",
    "indexer:build": "make -C services/indexer build",
    "indexer:test": "make -C services/indexer test",
    "indexer:lint": "make -C services/indexer lint",
    "indexer:migrate": "make -C services/indexer migrate",
    "tui-indexer:build": "make -C services/tui-indexer build",
    "tui-indexer:test": "make -C services/tui-indexer test",
    "tui-indexer:test:all": "make -C services/tui-indexer test-all",
    "tui-indexer:lint": "make -C services/tui-indexer lint",
    "tui-indexer:migrate": "make -C services/tui-indexer migrate",
    "tui-indexer:run:serve": "make -C services/tui-indexer run-serve",
    "tui-indexer:run:live": "make -C services/tui-indexer run-live",
    "tui-indexer:run:backfill": "make -C services/tui-indexer run-backfill",
    "tui-indexer:infra:up": "sh -c 'if docker compose version >/dev/null 2>&1; then docker compose -f infra/docker-compose.yml -f infra/docker-compose.tui-indexer.yml up -d; else docker-compose -f infra/docker-compose.yml -f infra/docker-compose.tui-indexer.yml up -d; fi'",
    "tui-indexer:infra:down": "sh -c 'if docker compose version >/dev/null 2>&1; then docker compose -f infra/docker-compose.yml -f infra/docker-compose.tui-indexer.yml down; else docker-compose -f infra/docker-compose.yml -f infra/docker-compose.tui-indexer.yml down; fi'"
  },
  "packageManager": "bun@1.2.15"
}
